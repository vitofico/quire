<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Kotlin packages stay io.theficos.ereader.*; android namespace is io.theficos.quire.
         Component android:name attributes must be fully-qualified (io.theficos.ereader.Foo),
         not relative (.Foo) — relative names resolve against the namespace and won't match. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name="io.theficos.ereader.EReaderApp"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Quire">
        <!-- configChanges keeps the Activity alive across rotation/keyboard/navigation
             changes. Required because EpubNavigatorFragment has no no-arg constructor:
             on Activity recreation, FragmentManager.restoreSaveStateInternal tries to
             instantiate it via reflection before our custom FragmentFactory has been
             installed (the factory is set inside Compose, well after super.onCreate),
             and the restore crashes with Fragment$InstantiationException. Compose
             handles configuration changes natively via LocalConfiguration, so keeping
             the Activity alive is safe. uiMode/locale/density/fontScale intentionally
             stay off the list so theme and locale changes still recreate. -->
        <activity
            android:name="io.theficos.ereader.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|navigation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>
